# Copy to .env and fill in. Never commit .env (NREQ-006).
REQPILOT_PROVIDER=groq            # groq | anthropic | ollama | mock
GROQ_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
GROQ_MODEL=llama-3.3-70b-versatile
ANTHROPIC_MODEL=claude-sonnet-5
OLLAMA_MODEL=llama3.1

# ASR model dirs — defaults point at the InkVoice checkouts if present;
# run scripts/fetch_models.py to download to ./models on a fresh machine.
# REQPILOT_OFFLINE_MODEL_DIR=
# REQPILOT_STREAMING_MODEL_DIR=

REQPILOT_HOST=127.0.0.1
REQPILOT_PORT=8765
REQPILOT_DATA_DIR=./data
